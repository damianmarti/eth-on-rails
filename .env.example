# Root env example for ETH on Rails.
# Per-package env files also exist: packages/hardhat/.env.example,
# packages/foundry/.env.example.

# RPC provider key (Alchemy). The bundled default is a public Scaffold-ETH key;
# set your own for production / live networks.
ALCHEMY_API_KEY=

# WalletConnect / Reown project id (https://dashboard.reown.com).
# Needed for WalletConnect-based wallets; injected wallets + burner work without it.
WALLET_CONNECT_PROJECT_ID=

# Override the local faucet signer (defaults to anvil/hardhat account #0).
# FAUCET_PRIVATE_KEY=

# Contract deployment (live networks). Prefer the encrypted keystore flows:
#   yarn account:generate / yarn account:import
# DEPLOYER_PRIVATE_KEY=
# ETHERSCAN_V2_API_KEY=
