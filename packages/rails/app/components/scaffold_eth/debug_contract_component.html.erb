<div class="grid lg:grid-cols-3 gap-6">
  <%# ---- Left column: contract info + auto-refreshing variables ---- %>
  <div class="lg:col-span-1 flex flex-col gap-6">
    <div class="bg-base-100 border border-base-300 rounded-3xl shadow-md shadow-secondary px-6 py-5">
      <div class="flex items-center gap-2">
        <h2 class="font-bold text-lg"><%= contract.name %></h2>
      </div>
      <div class="text-sm mt-1">
        <%= render ScaffoldEth::AddressComponent.new(address: contract.address, size: "sm", resolve_ens: false) %>
      </div>
      <div class="text-sm flex items-center gap-1 mt-1">
        <span class="font-bold">Balance:</span>
        <%= render ScaffoldEth::BalanceComponent.new(address: contract.address) %>
      </div>
      <div class="text-sm mt-1">
        <span class="font-bold">Network:</span>
        <span style="color: <%= helpers.active_chain.color %>"><%= helpers.active_chain.name %></span>
      </div>
    </div>

    <%# Contract Variables — zero-input view functions, auto-refreshing (eth.rb) %>
    <% if variable_functions.any? %>
      <div class="bg-secondary border border-base-300 rounded-3xl shadow-lg shadow-base-300 px-6 py-5">
        <div class="flex items-center gap-2 mb-2">
          <span class="badge badge-sm badge-ghost">eth.rb · server</span>
        </div>
        <div class="divide-y divide-base-content/10">
          <% variable_functions.each do |fn| %>
            <%= render ScaffoldEth::DisplayVariableComponent.new(contract: contract, function: fn) %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ---- Right column: Read (inputs) + Write ---- %>
  <div class="lg:col-span-2 flex flex-col gap-6">
    <%# ---------- READ (input-taking, server-side via eth.rb) ---------- %>
    <section class="bg-base-100 border border-base-300 rounded-3xl shadow-md shadow-secondary px-6 py-5 relative mt-4">
      <div class="absolute -top-[14px] left-6 bg-base-300 px-4 py-1 text-sm font-medium shadow-sm">Read</div>
      <div class="flex items-center gap-2 mb-3 mt-1">
        <span class="badge badge-sm badge-ghost">eth.rb · server</span>
      </div>

      <% if read_functions.empty? %>
        <p class="text-sm opacity-60">No read functions with inputs.</p>
      <% end %>

      <% read_functions.each do |fn| %>
        <div class="py-3 border-t border-base-200 first:border-0"
             data-controller="debug-read"
             data-debug-read-contract-value="<%= contract.name %>"
             data-debug-read-function-value="<%= fn['name'] %>">
          <div class="font-medium text-sm mb-1"><%= fn['name'] %></div>

          <% fn['inputs'].each_with_index do |input, i| %>
            <%= render ScaffoldEth::ContractInputComponent.new(abi_input: input, index: i, function_name: "#{fn['name']}_r") %>
          <% end %>

          <div class="flex items-center gap-3 mt-1">
            <button type="button" class="btn btn-xs btn-secondary rounded-full"
                    data-action="debug-read#read">Read 📡</button>
            <span class="font-mono text-sm break-all" data-debug-read-target="output"></span>
          </div>
        </div>
      <% end %>
    </section>

    <%# ---------- WRITE (browser-signed via viem) ---------- %>
    <section class="bg-base-100 border border-base-300 rounded-3xl shadow-md shadow-secondary px-6 py-5 relative mt-4">
      <div class="absolute -top-[14px] left-6 bg-base-300 px-4 py-1 text-sm font-medium shadow-sm">Write</div>
      <div class="flex items-center gap-2 mb-3 mt-1">
        <span class="badge badge-sm badge-ghost">viem · wallet</span>
      </div>

      <% if write_functions.empty? %>
        <p class="text-sm opacity-60">No write functions.</p>
      <% end %>

      <% write_functions.each do |fn| %>
        <div class="py-3 border-t border-base-200 first:border-0"
             data-controller="scaffold-write-contract"
             data-scaffold-write-contract-contract-value="<%= contract.name %>"
             data-scaffold-write-contract-function-value="<%= fn['name'] %>">
          <div class="font-medium text-sm mb-2">
            <%= fn['name'] %>
            <% if payable?(fn) %><span class="badge badge-xs badge-warning">payable</span><% end %>
          </div>

          <% fn['inputs'].each_with_index do |input, i| %>
            <%= render ScaffoldEth::ContractInputComponent.new(abi_input: input, index: i, function_name: fn['name']) %>
          <% end %>

          <% if payable?(fn) %>
            <label class="block text-xs font-medium opacity-70 mb-1 ml-1 mt-2">payable value (ETH)</label>
            <%= render ScaffoldEth::EtherInputComponent.new(name: "#{fn['name']}__value") %>
          <% end %>

          <button type="button" class="btn btn-sm btn-primary rounded-full mt-2"
                  data-scaffold-write-contract-target="button"
                  data-action="scaffold-write-contract#submit">
            Send 💸
          </button>
        </div>
      <% end %>
    </section>

    <%# ---------- EVENTS ---------- %>
    <% events.each do |event| %>
      <section class="bg-base-100 border border-base-300 rounded-3xl shadow-md shadow-secondary px-6 py-5"
               data-controller="scaffold-event-history scaffold-watch-event"
               data-scaffold-event-history-contract-value="<%= contract.name %>"
               data-scaffold-event-history-event-value="<%= event['name'] %>"
               data-scaffold-watch-event-contract-value="<%= contract.name %>"
               data-scaffold-watch-event-event-value="<%= event['name'] %>">
        <h3 class="font-bold mb-2">Event · <%= event['name'] %></h3>
        <p class="hidden text-sm opacity-60" data-scaffold-event-history-target="empty">No events yet.</p>
        <div class="overflow-x-auto">
          <table class="table table-xs">
            <thead><tr><th>Block</th><th>Args</th><th>Tx</th></tr></thead>
            <tbody data-scaffold-event-history-target="list" data-scaffold-watch-event-target="list"></tbody>
          </table>
        </div>
      </section>
    <% end %>
  </div>
</div>
