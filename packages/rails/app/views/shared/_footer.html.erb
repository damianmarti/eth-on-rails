<footer class="shrink-0 bg-base-100 border-t border-base-300 py-4 px-4">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-3 max-w-6xl mx-auto">
    <div class="flex items-center gap-2 text-sm">
      <% if active_chain.local? %>
        <%= link_to faucet_path, class: "btn btn-sm btn-primary rounded-full gap-1" do %>
          💰 <span>Faucet</span>
        <% end %>
        <%= link_to block_explorer_path, class: "btn btn-sm btn-primary rounded-full gap-1" do %>
          🔍 <span>Block Explorer</span>
        <% end %>
      <% end %>
    </div>

    <div class="flex items-center gap-3 text-sm">
      <span class="opacity-70">Built with eth.rb + viem on Rails</span>
      <%# Theme toggle (light/dark) %>
      <label class="swap swap-rotate" data-action="change->theme#toggle">
        <input type="checkbox" data-theme-target="toggle" />
        <span class="swap-on">🌞</span>
        <span class="swap-off">🌙</span>
      </label>
    </div>
  </div>
</footer>
