<header class="sticky lg:static top-0 z-20 navbar bg-base-100 border-b-2 border-base-300 min-h-16 shrink-0 justify-between px-2 sm:px-4">
  <div class="navbar-start gap-2 self-stretch w-auto">
    <%= link_to root_path, class: "flex items-center gap-2 ml-2 mr-6 shrink-0" do %>
      <div class="flex items-center justify-center w-10 h-10 bg-base-300 text-2xl shrink-0">🏗️</div>
      <div class="flex flex-col leading-tight">
        <span class="font-bold">ETH on Rails</span>
        <span class="text-xs">Ethereum dev stack</span>
      </div>
    <% end %>

    <nav class="hidden lg:flex items-stretch self-stretch">
      <%= nav_link "Home", root_path %>
      <%= nav_link "Example", example_path, icon: sparkles_icon %>
      <%= nav_link "Debug Contracts", debug_path, icon: bug_ant_icon %>
    </nav>
  </div>

  <div class="navbar-end grow gap-2 pr-2">
    <%# Reown AppKit connect button + network badge (Stimulus-driven) %>
    <%= render ScaffoldEth::ConnectButtonComponent.new %>
    <% if active_chain.local? %>
      <button class="btn btn-sm btn-ghost hidden sm:inline-flex"
              data-controller="burner" data-action="click->burner#toggle"
              title="Connect a throwaway local account">
        🔥 <span data-burner-target="label">Burner</span>
        <span class="font-mono text-xs opacity-70" data-burner-target="address"></span>
      </button>
      <%= render ScaffoldEth::FaucetButtonComponent.new %>
    <% end %>
  </div>
</header>

<%# mobile nav %>
<nav class="lg:hidden flex items-stretch justify-center bg-base-100 border-b border-base-300 h-10">
  <%= nav_link "Home", root_path %>
  <%= nav_link "Example", example_path, icon: sparkles_icon %>
  <%= nav_link "Debug Contracts", debug_path, icon: bug_ant_icon %>
</nav>
