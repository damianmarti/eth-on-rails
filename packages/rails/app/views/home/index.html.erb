<% content_for :title, "ETH on Rails" %>

<div class="flex items-center flex-col grow pt-10">
  <div class="px-5">
    <h1 class="text-center">
      <span class="block text-2xl mb-2">Welcome to</span>
      <span class="block text-4xl font-bold">🏗️ ETH on Rails</span>
    </h1>

    <div class="flex justify-center items-center space-x-2 flex-col">
      <p class="my-2 font-medium">Connected Address:</p>
      <div data-controller="account-display" data-account-display-target="container">
        <%= render ScaffoldEth::AddressComponent.new(address: nil, placeholder: "Connect your wallet") %>
      </div>
    </div>

    <p class="text-center text-lg">
      A Scaffold-ETH&nbsp;2 toolkit built on <strong>Ruby on Rails</strong> + <strong>eth.rb</strong>,
      with a faithful <strong>viem&nbsp;+&nbsp;Reown&nbsp;AppKit</strong> wallet layer.
    </p>
    <p class="text-center text-lg">
      Get started by editing
      <code class="italic bg-base-300 text-base font-bold max-w-full break-words break-all inline-block">
        packages/rails/app/views/home/index.html.erb
      </code>
    </p>
    <p class="text-center text-lg">
      Edit your smart contract
      <code class="italic bg-base-300 text-base font-bold max-w-full break-words break-all inline-block">
        YourContract.sol
      </code>
      in
      <code class="italic bg-base-300 text-base font-bold max-w-full break-words break-all inline-block">
        packages/hardhat/contracts
      </code>
    </p>
  </div>

  <div class="grow bg-base-300 w-full mt-16 px-8 py-12">
    <div class="flex justify-center items-center gap-12 flex-col md:flex-row">
      <div class="flex flex-col bg-base-100 relative text-center items-center max-w-xs rounded-3xl border border-base-300 px-10 py-10">
        <div class="text-3xl mb-2">🐛</div>
        <p>
          Tinker with your smart contract using the
          <%= link_to "Debug Contracts", debug_path, class: "link" %> tab.
        </p>
      </div>
      <div class="flex flex-col bg-base-100 relative text-center items-center max-w-xs rounded-3xl border border-base-300 px-10 py-10">
        <div class="text-3xl mb-2">🔍</div>
        <p>
          Explore your local transactions with the
          <%= link_to "Block Explorer", block_explorer_path, class: "link" %> tab.
        </p>
      </div>
    </div>

    <% if deployed_contract_names.any? %>
      <div class="text-center text-sm opacity-70 mt-10">
        Deployed on <strong><%= active_chain.name %></strong>: <%= deployed_contract_names.join(", ") %>
      </div>
    <% else %>
      <div class="text-center text-sm opacity-70 mt-10">
        No contracts deployed yet — run
        <code class="px-1 bg-base-100 rounded">yarn deploy</code> or
        <code class="px-1 bg-base-100 rounded">yarn foundry:deploy</code> from the repo root.
      </div>
    <% end %>
  </div>
</div>
