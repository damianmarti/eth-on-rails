<% content_for :title, "Transaction" %>

<div class="max-w-4xl mx-auto w-full px-4 py-6">
  <%= link_to "← Back to explorer", block_explorer_path, class: "link text-sm" %>
  <h1 class="text-2xl font-bold mt-2 mb-4 flex items-center gap-2">
    Transaction <%= tx_status_badge(@transaction[:status]) %>
  </h1>

  <div class="bg-base-100 rounded-2xl shadow p-5 space-y-2 text-sm">
    <% [
      ["Tx hash", @transaction[:hash]],
      ["Block", link_to("##{@transaction[:block_number]}", block_explorer_block_path(@transaction[:block_number]), class: "link")],
      ["From", link_to(@transaction[:from], block_explorer_address_path(@transaction[:from]), class: "link")],
      ["To", @transaction[:to] ? link_to(@transaction[:to], block_explorer_address_path(@transaction[:to]), class: "link") : "Contract creation: #{@transaction[:contract_address]}"],
      ["Value", "#{format_eth(@transaction[:value])} ETH"],
      ["Gas used", number_with_delimiter(@transaction[:gas_used])],
      ["Gas price", "#{format_gwei(@transaction[:gas_price])} gwei"],
      ["Nonce", @transaction[:nonce]],
    ].each do |label, value| %>
      <div class="flex flex-col sm:flex-row sm:gap-3">
        <span class="opacity-60 w-32 shrink-0"><%= label %></span>
        <span class="font-mono break-all"><%= value %></span>
      </div>
    <% end %>

    <div class="flex flex-col sm:flex-row sm:gap-3">
      <span class="opacity-60 w-32 shrink-0">Input data</span>
      <span class="font-mono break-all text-xs bg-base-200 rounded p-2 flex-1"><%= @transaction[:input] %></span>
    </div>
  </div>

  <% if @transaction[:logs].any? %>
    <h2 class="text-lg font-bold mt-6 mb-2">Logs (<%= @transaction[:logs].size %>)</h2>
    <div class="bg-base-100 rounded-2xl shadow p-4 space-y-3">
      <% @transaction[:logs].each do |log| %>
        <div class="text-xs font-mono break-all border-b border-base-200 pb-2">
          <div><span class="opacity-60">address:</span> <%= log["address"] %></div>
          <div><span class="opacity-60">topics:</span> <%= Array(log["topics"]).join(", ") %></div>
          <div><span class="opacity-60">data:</span> <%= log["data"] %></div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
