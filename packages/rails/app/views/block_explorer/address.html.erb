<% content_for :title, "Address" %>

<div class="max-w-5xl mx-auto w-full px-4 py-6">
  <%= link_to "← Back to explorer", block_explorer_path, class: "link text-sm" %>
  <h1 class="text-2xl font-bold mt-2 mb-4 flex items-center gap-2">
    Address
    <% if @info[:is_contract] %><span class="badge badge-secondary">Contract</span><% end %>
  </h1>

  <div class="bg-base-100 rounded-2xl shadow p-5 space-y-3 text-sm mb-4">
    <div class="text-base">
      <%= render ScaffoldEth::AddressComponent.new(address: @info[:address], format: "long", resolve_ens: false) %>
    </div>
    <div class="flex flex-col sm:flex-row sm:gap-3">
      <span class="opacity-60 w-32 shrink-0">Balance</span>
      <span class="font-mono"><%= format_eth(@info[:balance]) %> <%= active_chain.symbol %></span>
    </div>
    <div class="flex flex-col sm:flex-row sm:gap-3">
      <span class="opacity-60 w-32 shrink-0">Nonce / Txns</span>
      <span class="font-mono"><%= @info[:nonce] %></span>
    </div>
    <% if @info[:is_contract] && deployed_contract_names.include?(name_for_address(@info[:address])) %>
      <%= link_to "Open in Debug Contracts →", debug_contract_path(name_for_address(@info[:address])), class: "link link-primary" %>
    <% end %>
  </div>

  <%# Tabs %>
  <div role="tablist" class="tabs tabs-boxed mb-3 inline-flex">
    <%= link_to "Transactions", block_explorer_address_path(@info[:address], tab: "transactions"),
          role: "tab", class: "tab #{'tab-active' if @tab == 'transactions'}" %>
    <% if @info[:is_contract] %>
      <%= link_to "Code", block_explorer_address_path(@info[:address], tab: "code"),
            role: "tab", class: "tab #{'tab-active' if @tab == 'code'}" %>
    <% end %>
    <%= link_to "Logs", block_explorer_address_path(@info[:address], tab: "logs"),
          role: "tab", class: "tab #{'tab-active' if @tab == 'logs'}" %>
  </div>

  <div class="bg-base-100 rounded-2xl shadow overflow-x-auto">
    <% case @tab %>
    <% when "code" %>
      <div class="p-4">
        <div class="text-xs opacity-60 mb-1">Bytecode (<%= number_with_delimiter((@code.to_s.length - 2) / 2) %> bytes)</div>
        <pre class="font-mono text-xs break-all whitespace-pre-wrap bg-base-200 rounded p-3 max-h-96 overflow-y-auto"><%= @code %></pre>
      </div>
    <% when "logs" %>
      <div class="p-4 space-y-3">
        <% logs = @explorer.logs_for(@info[:address]) %>
        <% if logs.empty? %>
          <p class="text-sm opacity-60">No recent logs.</p>
        <% else %>
          <% logs.each do |log| %>
            <div class="text-xs font-mono break-all border-b border-base-200 pb-2">
              <div><span class="opacity-60">block:</span> <%= log["blockNumber"].to_i(16) rescue log["blockNumber"] %></div>
              <div><span class="opacity-60">topics:</span> <%= Array(log["topics"]).join(", ") %></div>
              <div><span class="opacity-60">data:</span> <%= log["data"] %></div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <table class="table table-sm">
        <thead><tr class="text-xs"><th>Tx Hash</th><th>Function</th><th>Block</th><th>From</th><th>To</th><th class="text-end">Value</th></tr></thead>
        <tbody>
          <% if @transactions.empty? %>
            <tr><td colspan="6" class="text-center opacity-60 py-6">No transactions found.</td></tr>
          <% end %>
          <% @transactions.each do |tx| %>
            <tr>
              <td><%= link_to "#{tx[:hash][0, 10]}…", block_explorer_tx_path(tx[:hash]), class: "link link-primary font-mono text-xs" %></td>
              <td><%= function_called_badge(tx[:function]) %></td>
              <td class="font-mono text-xs"><%= tx[:block_number] %></td>
              <td><%= render ScaffoldEth::AddressComponent.new(address: tx[:from], size: "xs", resolve_ens: false) %></td>
              <td>
                <% if tx[:contract_creation] %><span class="badge badge-xs badge-ghost">Contract Creation</span>
                <% elsif tx[:to] %><%= render ScaffoldEth::AddressComponent.new(address: tx[:to], size: "xs", resolve_ens: false) %><% end %>
              </td>
              <td class="text-end font-mono text-xs"><%= format_eth(tx[:value]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
