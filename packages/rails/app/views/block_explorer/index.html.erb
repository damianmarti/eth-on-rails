<% content_for :title, "Block Explorer" %>

<div class="max-w-6xl mx-auto w-full px-4 py-6">
  <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
    <h1 class="text-2xl font-bold">🔍 Block Explorer</h1>
    <span class="text-sm opacity-70">Latest block: <strong>#<%= @latest_number %></strong> · <%= active_chain.name %></span>
  </div>

  <%= form_with url: block_explorer_search_path, method: :get, class: "mb-6" do |f| %>
    <div class="join w-full">
      <%= f.text_field :q, placeholder: "Search by tx hash, address, or block #",
            class: "input input-bordered join-item w-full font-mono text-sm" %>
      <%= f.submit "Search", class: "btn btn-primary join-item" %>
    </div>
  <% end %>

  <div class="bg-base-100 rounded-2xl shadow overflow-x-auto"
       data-controller="block-stream" data-block-stream-url-value="<%= api_blocks_path %>"
       data-block-stream-latest-value="<%= @latest_number %>" data-block-stream-page-value="<%= @page %>">
    <table class="table table-sm">
      <thead>
        <tr class="text-xs">
          <th>Transaction Hash</th>
          <th>Function Called</th>
          <th>Block</th>
          <th>Time Mined</th>
          <th>From</th>
          <th>To</th>
          <th class="text-end">Value (<%= active_chain.symbol %>)</th>
        </tr>
      </thead>
      <tbody>
        <% if @transactions.empty? %>
          <tr><td colspan="7" class="text-center opacity-60 py-6">No transactions yet.</td></tr>
        <% end %>
        <% @transactions.each do |tx| %>
          <tr>
            <td>
              <%= link_to "#{tx[:hash][0, 12]}…", block_explorer_tx_path(tx[:hash]),
                    class: "link link-primary font-mono text-xs" %>
            </td>
            <td><%= function_called_badge(tx[:function]) %></td>
            <td>
              <%= link_to "#{tx[:block_number]}", block_explorer_block_path(tx[:block_number]),
                    class: "link font-mono text-xs" %>
            </td>
            <td class="text-xs opacity-70 whitespace-nowrap"><%= block_time_ago(tx[:timestamp]) %></td>
            <td><%= render ScaffoldEth::AddressComponent.new(address: tx[:from], size: "xs", resolve_ens: false) %></td>
            <td>
              <% if tx[:contract_creation] %>
                <span class="badge badge-xs badge-ghost">Contract Creation</span>
              <% elsif tx[:to] %>
                <%= render ScaffoldEth::AddressComponent.new(address: tx[:to], size: "xs", resolve_ens: false) %>
              <% end %>
            </td>
            <td class="text-end font-mono text-xs"><%= format_eth(tx[:value]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pages > 1 %>
    <div class="flex items-center justify-center gap-3 mt-4">
      <%= link_to "« Prev", block_explorer_path(page: @page - 1),
            class: "btn btn-sm rounded-full #{'btn-disabled' if @page <= 1}" %>
      <span class="text-sm opacity-70">Page <%= @page %> / <%= @pages %></span>
      <%= link_to "Next »", block_explorer_path(page: @page + 1),
            class: "btn btn-sm rounded-full #{'btn-disabled' if @page >= @pages}" %>
    </div>
  <% end %>
</div>
