# Alchemy (or other RPC provider) API key, used for live networks + mainnet forking
ALCHEMY_API_KEY=

# Etherscan V2 API key, used by `yarn verify`
ETHERSCAN_V2_API_KEY=

# Deployer key. Prefer the encrypted variant generated by `yarn generate` / `yarn account:import`.
# DEPLOYER_PRIVATE_KEY_ENCRYPTED=
# Plaintext fallback (NOT recommended for live networks):
# DEPLOYER_PRIVATE_KEY=

# Set to "true" to fork mainnet when running `yarn fork`
MAINNET_FORKING_ENABLED=false
